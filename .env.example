# .env.example — шаблон, можно коммитить

# 🗄️ PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=php_site
PGUSER=postgres
PGPASSWORD=your_secure_password

# 🌐 Приложение
APP_ENV=development
APP_URL=http://ponka.ru
APP_DEBUG=true

# 🔌 PHP-FPM / NGINX (опционально)
FASTCGI_HOST=127.0.0.1
FASTCGI_PORT=9000
